<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PARALLEL UNIVERSE — Gate of Singularity</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body {
  background:#070d18;
  overflow:hidden;
  height:100vh;
  font-family:'Cinzel Decorative', cursive;
  cursor:crosshair;
}
canvas { display:block; }

/* ── UI: SPACE ── */
#space-ui {
  position:fixed;
  inset:0;
  pointer-events:none;
  z-index:10;
  transition: opacity 1.5s ease;
}
.sp-title {
  position:absolute;
  top:40px;
  left:50%;
  transform:translateX(-50%);
  font-size:clamp(16px,2.5vw,28px);
  letter-spacing:8px;
  color:#c084fc;
  text-shadow:
    0 0 16px rgba(192,132,252,0.95),
    0 0 40px rgba(168,85,247,0.32);
  white-space:nowrap;
  transition: color 2s, text-shadow 2s;
}
.sp-title.glass-mode {
  color:#e0f4ff;
  text-shadow:
    0 0 16px rgba(224,244,255,0.85),
    0 0 40px rgba(100,200,255,0.35);
}
.sp-phase {
  position:absolute;
  top:86px;
  left:50%;
  transform:translateX(-50%);
  font-size:clamp(7px,0.85vw,10px);
  letter-spacing:7px;
  color:rgba(192,132,252,0.45);
  white-space:nowrap;
  transition: color 1.5s;
}
.sp-msg {
  position:absolute;
  bottom:70px;
  left:50%;
  transform:translateX(-50%);
  font-size:clamp(9px,1.1vw,13px);
  letter-spacing:5px;
  color:rgba(190,205,255,0.0);
  white-space:nowrap;
  transition: color 0.5s ease;
}
.sp-hint {
  position:absolute;
  bottom:22px;
  left:50%;
  transform:translateX(-50%);
  font-size:clamp(7px,0.8vw,9px);
  letter-spacing:5px;
  color:rgba(142,164,190,0.48);
  white-space:nowrap;
  transition: color 1s, opacity 1s;
  animation: pulse 3s infinite;
}

/* ── UI: OCEAN ── */
#ocean-ui {
  position:fixed;
  inset:0;
  pointer-events:none;
  z-index:20;
  opacity:0;
  transition: opacity 3s ease;
}
.oc-title {
  position:absolute;
  top:43px;
  left:50%;
  transform:translateX(-50%);
  font-size:clamp(14px,2.2vw,26px);
  letter-spacing:6px;
  color:#22d3ee;
  text-shadow:
    0 0 16px rgba(34,211,238,0.9),
    0 0 40px rgba(6,182,212,0.4);
  white-space:nowrap;
}
.oc-sub {
  position:absolute;
  bottom:18px;
  left:50%;
  transform:translateX(-50%);
  font-size:clamp(8px,1vw,11px);
  letter-spacing:5px;
  color:rgba(34,211,238,0.35);
  white-space:nowrap;
}
.oc-prompt {
  position:absolute;
  bottom:110px;
  left:50%;
  transform:translateX(-50%);
  font-size:clamp(11px,1.3vw,15px);
  letter-spacing:4px;
  color:rgba(34,211,238,0.6);
  white-space:nowrap;
  text-align:center;
  line-height:2.4;
  transition:opacity 0.8s ease;
}
.oc-bars {
  position:absolute;
  bottom:44px;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  gap:3px;
  align-items:flex-end;
  height:36px;
}
.oc-bars span {
  width:5px;
  background:rgba(34,211,238,0.5);
  border-radius:2px 2px 0 0;
  min-height:2px;
}

@keyframes pulse {
  0%, 100% { opacity:0.28; }
  50% { opacity:0.8; }
}
</style>
<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
  }
}
</script>
</head>
<body>

<div id="space-ui">
  <div class="sp-title" id="sp-title">CORE</div>
  <div class="sp-phase" id="sp-phase">WRIGGLING</div>
  <div class="sp-msg" id="sp-msg"></div>
  <div class="sp-hint" id="sp-hint">HOLD TO EVOLVE / 長押しで真理へ</div>
</div>

<div id="ocean-ui">
  <div class="oc-title">CRYSTAL</div>
  <div class="oc-prompt" id="oc-prompt">— click to activate —<br>クリックで波長を同期</div>
  <div class="oc-bars" id="oc-bars"></div>
  <div class="oc-sub">AUDIO VISUALIZER — TEAM PARALLEL</div>
</div>

<script type="module">
import * as THREE from 'three';
import { EffectComposer }  from 'three/addons/postprocessing/EffectComposer.js';
import { RenderPass }      from 'three/addons/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';

// ============================================================
// 1. 基本セットアップ
// ============================================================
const PAL = {
  spaceBg:0x070d18,
  oceanBg:0x04111d,
  oceanFog:0x082235,
  corePurple:0x745cff,
  coreLavender:0xbdaeff,
  coreCyan:0x22d3ee,
  deepCyan:0x0ea5d8,
  seabed:0x08283d,
  seabedGlow:0x02131d,
  surface:0x53dcff,
  curtain:0x8cefff,
  memoryBg:0x0d0b18,
  memoryAura:0x1a0f28
};

const scene  = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(42, innerWidth / innerHeight, 0.1, 300);
camera.position.set(0, 0, 14);

const renderer = new THREE.WebGLRenderer({
  antialias:true,
  powerPreference:"high-performance"
});
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
renderer.setSize(innerWidth, innerHeight);
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.18;
renderer.outputColorSpace = THREE.SRGBColorSpace;
renderer.setClearColor(PAL.spaceBg, 1); // #070d18
document.body.appendChild(renderer.domElement);

const composer = new EffectComposer(renderer);
composer.addPass(new RenderPass(scene, camera));
const bloomPass = new UnrealBloomPass(
  new THREE.Vector2(innerWidth, innerHeight),
  1.0,
  0.6,
  0.15
);
composer.addPass(bloomPass);

const spaceGroup = new THREE.Group();
const oceanGroup = new THREE.Group();
scene.add(spaceGroup);
scene.add(oceanGroup);
oceanGroup.visible = false;

// ============================================================
// 2. 宇宙（SPACE）の構築
// ============================================================
const bgOrbData = [
  { color:0x9f7dff, pos:[  9,  5,-22], r:5.5, op:0.08 },
  { color:0x22d3ee, pos:[-11, -3,-25], r:7.0, op:0.06 },
  { color:0xbdaeff, pos:[  1, -9,-20], r:6.0, op:0.07 },
  { color:0x3ea7ff, pos:[ -6,  8,-18], r:4.0, op:0.05 },
  { color:0x7cf2ff, pos:[ 12, -7,-30], r:8.0, op:0.04 }
];
bgOrbData.forEach(({ color, pos, r, op }) => {
  const mesh = new THREE.Mesh(
    new THREE.SphereGeometry(r, 16, 16),
    new THREE.MeshBasicMaterial({
      color,
      transparent:true,
      opacity:op,
      blending:THREE.AdditiveBlending,
      depthWrite:false
    })
  );
  mesh.position.set(...pos);
  spaceGroup.add(mesh);
});

const nebulaSpec = [
  { c:PAL.corePurple,   n:320 },
  { c:PAL.coreCyan,     n:260 },
  { c:PAL.coreLavender, n:240 },
  { c:0xffffff,         n:160 },
  { c:0x5cc8ff,         n:120 }
];

const nebulaParticles = [];
nebulaSpec.forEach(({ c, n }) => {
  const pos = new Float32Array(n * 3);
  for(let i=0;i<n;i++){
    const r  = 10 + Math.random() * 25;
    const th = Math.random() * Math.PI * 2;
    const ph = Math.acos(2 * Math.random() - 1);
    pos[i*3]   = r * Math.sin(ph) * Math.cos(th);
    pos[i*3+1] = r * Math.sin(ph) * Math.sin(th);
    pos[i*3+2] = r * Math.cos(ph);
  }

  const pts = new THREE.Points(
    new THREE.BufferGeometry().setAttribute(
      'position',
      new THREE.Float32BufferAttribute(pos, 3)
    ),
    new THREE.PointsMaterial({
      color:c,
      size:0.07 + Math.random() * 0.06,
      transparent:true,
      opacity:0.45,
      blending:THREE.AdditiveBlending,
      depthWrite:false
    })
  );

  spaceGroup.add(pts);
  nebulaParticles.push(pts);
});

const glitterDustPos = new Float32Array(1500 * 3);
for(let i=0; i<1500; i++){
  glitterDustPos[i*3]   = (Math.random() - 0.5) * 150;
  glitterDustPos[i*3+1] = (Math.random() - 0.5) * 150;
  glitterDustPos[i*3+2] = (Math.random() - 0.5) * 100;
}
const glitterDust = new THREE.Points(
  new THREE.BufferGeometry().setAttribute(
    'position',
    new THREE.Float32BufferAttribute(glitterDustPos, 3)
  ),
  new THREE.PointsMaterial({
    color:0xe7f6ff,
    size:0.05,
    transparent:true,
    opacity:0.38,
    blending:THREE.AdditiveBlending,
    depthWrite:false
  })
);
spaceGroup.add(glitterDust);

const cubeRT = new THREE.WebGLCubeRenderTarget(256, {
  format:THREE.RGBAFormat,
  generateMipmaps:true,
  minFilter:THREE.LinearMipmapLinearFilter
});
const cubeCamera = new THREE.CubeCamera(0.5, 150, cubeRT);
spaceGroup.add(cubeCamera);

const spLightGroup = new THREE.Group();
spLightGroup.add(new THREE.AmbientLight(0x0b1230, 1.45));
const dynLights = [
  { l: new THREE.PointLight(PAL.corePurple, 4.6, 35), b:[ 5, 5, 7] },
  { l: new THREE.PointLight(PAL.coreCyan,   3.8, 30), b:[-5,-3, 5] }
];
dynLights.forEach(({ l, b }) => {
  l.position.set(...b);
  spLightGroup.add(l);
});
spaceGroup.add(spLightGroup);

const RADIUS = 2.0;
const sphereGeo = new THREE.SphereGeometry(RADIUS, 90, 90);
const origPos = new Float32Array(sphereGeo.attributes.position.array);
const vertN = origPos.length / 3;

const noiseFreq  = new Float32Array(vertN);
const noiseAmpR  = new Float32Array(vertN);
const noiseAmpT  = new Float32Array(vertN);
const noisePhase = new Float32Array(vertN);

for(let i=0; i<vertN; i++){
  noiseFreq[i]  = 0.6 + Math.random() * 1.4;
  noiseAmpR[i]  = 0.06 + Math.random() * 0.28;
  noiseAmpT[i]  = 0.03 + Math.random() * 0.12;
  noisePhase[i] = Math.random() * Math.PI * 2;
}

const PW = { cR:0.22, cG:0.14, cB:0.96, em:0.84, m:0.10, r:0.36, op:0.92 };
const PG = { cR:0.8,  cG:0.95, cB:1.0,  em:0.0,  m:0.1,  r:0.0,  op:1.0 };
const CONV_DUR = 3.5;

const matCore = new THREE.MeshPhysicalMaterial({
  color: new THREE.Color(PW.cR, PW.cG, PW.cB),
  emissive: new THREE.Color(0.10, 0.08, 0.55),
  emissiveIntensity: PW.em,
  metalness: PW.m,
  roughness: PW.r,
  transparent: true,
  opacity: PW.op,
  transmission: 0.0,
  ior: 2.1,
  clearcoat: 1.0,
  side: THREE.FrontSide
});
const coreMesh = new THREE.Mesh(sphereGeo, matCore);
spaceGroup.add(coreMesh);

const wireMat = new THREE.MeshBasicMaterial({
  color: PAL.coreLavender,
  wireframe: true,
  transparent: true,
  opacity: 0.07,
  blending: THREE.AdditiveBlending,
  depthWrite: false
});
const wireMesh = new THREE.Mesh(sphereGeo, wireMat);
wireMesh.scale.setScalar(1.003);
spaceGroup.add(wireMesh);

const fresnelMat = new THREE.ShaderMaterial({
  uniforms: {
    color:{ value: new THREE.Color(0xc26cff) },
    fresnelBias:{ value: 0.0 },
    fresnelScale:{ value: 1.5 },
    fresnelPower:{ value: 3.0 },
    opacity:{ value: 0.8 }
  },
  vertexShader: `
    varying vec3 vViewPosition;
    varying vec3 vNormal;
    void main() {
      vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
      vViewPosition = -mvPosition.xyz;
      vNormal = normalize(normalMatrix * normal);
      gl_Position = projectionMatrix * mvPosition;
    }
  `,
  fragmentShader: `
    uniform vec3 color;
    uniform float fresnelBias;
    uniform float fresnelScale;
    uniform float fresnelPower;
    uniform float opacity;
    varying vec3 vViewPosition;
    varying vec3 vNormal;
    void main() {
      vec3 viewDir = normalize(vViewPosition);
      float f = fresnelBias + fresnelScale * pow(1.0 - max(dot(viewDir, vNormal), 0.0), fresnelPower);
      gl_FragColor = vec4(color * f, f * opacity);
    }
  `,
  transparent: true,
  blending: THREE.AdditiveBlending,
  depthWrite: false
});
const fresnelMesh = new THREE.Mesh(sphereGeo, fresnelMat);
fresnelMesh.scale.setScalar(1.008);
spaceGroup.add(fresnelMesh);

const bloom1Mat = new THREE.MeshBasicMaterial({
  color: 0x9b6dff,
  transparent: true,
  opacity: 0.06,
  blending: THREE.AdditiveBlending,
  depthWrite: false,
  side: THREE.BackSide
});
const bloom2Mat = new THREE.MeshBasicMaterial({
  color: 0x39dfff,
  transparent: true,
  opacity: 0.028,
  blending: THREE.AdditiveBlending,
  depthWrite: false,
  side: THREE.BackSide
});
const bloomShell1 = new THREE.Mesh(new THREE.SphereGeometry(RADIUS * 1.35, 28, 28), bloom1Mat);
const bloomShell2 = new THREE.Mesh(new THREE.SphereGeometry(RADIUS * 1.85, 28, 28), bloom2Mat);
spaceGroup.add(bloomShell1, bloomShell2);

const CORE_GLITTER_COUNT = 1400;
const coreGlitterPos  = new Float32Array(CORE_GLITTER_COUNT * 3);
const coreGlitterBase = new Float32Array(CORE_GLITTER_COUNT * 3);
const coreGlitterSeed = new Float32Array(CORE_GLITTER_COUNT);
const coreGlitterCol  = new Float32Array(CORE_GLITTER_COUNT * 3);

for(let i=0; i<CORE_GLITTER_COUNT; i++){
  const r  = RADIUS * (1.02 + Math.random() * 0.42);
  const th = Math.random() * Math.PI * 2;
  const ph = Math.acos(2 * Math.random() - 1);
  const x = r * Math.sin(ph) * Math.cos(th);
  const y = r * Math.sin(ph) * Math.sin(th);
  const z = r * Math.cos(ph);

  coreGlitterPos[i*3]   = coreGlitterBase[i*3]   = x;
  coreGlitterPos[i*3+1] = coreGlitterBase[i*3+1] = y;
  coreGlitterPos[i*3+2] = coreGlitterBase[i*3+2] = z;
  coreGlitterSeed[i] = Math.random() * Math.PI * 2;

  const roll = Math.random();
  const c = roll < 0.34
    ? new THREE.Color(0xffffff)
    : roll < 0.68
      ? new THREE.Color(0xbfefff)
      : new THREE.Color(0xb68cff);

  coreGlitterCol[i*3]   = c.r;
  coreGlitterCol[i*3+1] = c.g;
  coreGlitterCol[i*3+2] = c.b;
}
const coreGlitterGeo = new THREE.BufferGeometry()
  .setAttribute('position', new THREE.BufferAttribute(coreGlitterPos, 3))
  .setAttribute('color', new THREE.BufferAttribute(coreGlitterCol, 3));

const coreGlitterMat = new THREE.PointsMaterial({
  size: 0.048,
  vertexColors: true,
  transparent: true,
  opacity: 0.72,
  blending: THREE.AdditiveBlending,
  depthWrite: false
});
const coreGlitter = new THREE.Points(coreGlitterGeo, coreGlitterMat);
spaceGroup.add(coreGlitter);

const flashMat = new THREE.MeshBasicMaterial({
  color:0xffffff,
  transparent:true,
  opacity:0.0,
  depthWrite:false,
  blending:THREE.AdditiveBlending
});
const flashMesh = new THREE.Mesh(new THREE.PlaneGeometry(100,100), flashMat);
flashMesh.position.z = 10;
scene.add(flashMesh);

// ============================================================
// 2.5 帰還後の小さな黄色コア
// ============================================================
const memoryCorePivot = new THREE.Group();
memoryCorePivot.visible = false;

const memoryCore = new THREE.Mesh(
  new THREE.IcosahedronGeometry(0.26, 0),
  new THREE.MeshBasicMaterial({
    color: 0xffdd55,
    transparent: true,
    opacity: 0.95,
    blending: THREE.AdditiveBlending,
    depthWrite: false
  })
);

const memoryCoreHalo = new THREE.Mesh(
  new THREE.IcosahedronGeometry(0.48, 0),
  new THREE.MeshBasicMaterial({
    color: 0xffb300,
    transparent: true,
    opacity: 0.26,
    blending: THREE.AdditiveBlending,
    wireframe: true,
    depthWrite: false
  })
);
memoryCorePivot.add(memoryCore, memoryCoreHalo);
spaceGroup.add(memoryCorePivot);

const memoryCoreTrail = new THREE.Mesh(
  new THREE.SphereGeometry(0.72, 18, 18),
  new THREE.MeshBasicMaterial({
    color: 0xfff1a8,
    transparent: true,
    opacity: 0.05,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
    side: THREE.BackSide
  })
);
memoryCorePivot.add(memoryCoreTrail);

// ============================================================
// 3. 深海（OCEAN）の構築
// ============================================================
const O_BUBBLE_COUNT = 180;
const bubblePos2 = new Float32Array(O_BUBBLE_COUNT * 3);
const bubbleSpd  = new Float32Array(O_BUBBLE_COUNT);
const bubbleDrf  = new Float32Array(O_BUBBLE_COUNT);

for(let i=0;i<O_BUBBLE_COUNT;i++){
  bubblePos2[i*3]   = (Math.random()-.5)*20;
  bubblePos2[i*3+1] = (Math.random()-.5)*20;
  bubblePos2[i*3+2] = (Math.random()-.5)*10;
  bubbleSpd[i] = 0.008 + Math.random() * 0.014;
  bubbleDrf[i] = Math.random() * Math.PI * 2;
}
const bubbleGeo = new THREE.BufferGeometry().setAttribute(
  'position',
  new THREE.BufferAttribute(bubblePos2, 3)
);
oceanGroup.add(new THREE.Points(
  bubbleGeo,
  new THREE.PointsMaterial({
    color:0x7fffff,
    size:0.10,
    transparent:true,
    opacity:0.45,
    blending:THREE.AdditiveBlending,
    depthWrite:false,
    sizeAttenuation:true
  })
));

const plankPts = [];
for(let i=0;i<600;i++){
  plankPts.push(
    (Math.random()-.5)*40,
    (Math.random()-.5)*40,
    (Math.random()-.5)*25
  );
}
oceanGroup.add(new THREE.Points(
  new THREE.BufferGeometry().setAttribute(
    'position',
    new THREE.Float32BufferAttribute(plankPts,3)
  ),
  new THREE.PointsMaterial({
    color:0x00ffcc,
    size:0.035,
    transparent:true,
    opacity:0.18,
    blending:THREE.AdditiveBlending,
    depthWrite:false
  })
));

const seabedGeo = new THREE.PlaneGeometry(30, 24, 70, 56);
const seabedPos = seabedGeo.attributes.position;
for(let i=0; i<seabedPos.count; i++){
  seabedPos.setZ(
    i,
    Math.sin(seabedPos.getX(i)*0.22)*0.55 +
    Math.cos(seabedPos.getY(i)*0.18)*0.35 +
    Math.sin((seabedPos.getX(i)+seabedPos.getY(i))*0.14)*0.28
  );
}
seabedGeo.computeVertexNormals();

const seabed = new THREE.Mesh(
  seabedGeo,
  new THREE.MeshPhysicalMaterial({
    color: PAL.seabed,
    emissive: new THREE.Color(PAL.seabedGlow),
    emissiveIntensity: 0.22,
    roughness: 0.96,
    metalness: 0.02,
    transparent: true,
    opacity: 0.96,
    side: THREE.DoubleSide
  })
);
seabed.rotation.x = -Math.PI / 2;
seabed.position.y = -6.2;
oceanGroup.add(seabed);

const seaLineMat = new THREE.LineBasicMaterial({
  color:0x0c5478,
  transparent:true,
  opacity:0.22
});
for(let k=0;k<6;k++){
  const pts = [];
  for(let j=0;j<20;j++){
    pts.push(new THREE.Vector3(
      -10 + j*1.05,
      -4.6 - k*0.46 + (Math.random()-.5)*0.20,
      -3.2 - k*1.15
    ));
  }
  oceanGroup.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), seaLineMat));
}

const waterSurfaceGeo = new THREE.PlaneGeometry(34, 28, 90, 72);
const waterSurfaceBase = waterSurfaceGeo.attributes.position.array.slice();
const waterSurface = new THREE.Mesh(
  waterSurfaceGeo,
  new THREE.MeshBasicMaterial({
    color: PAL.surface,
    transparent: true,
    opacity: 0.13,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
    side: THREE.DoubleSide
  })
);
waterSurface.rotation.x = -Math.PI / 2;
waterSurface.position.y = 6.2;
oceanGroup.add(waterSurface);

const rays = [];
for(let i=0;i<18;i++){
  const rMat = new THREE.MeshBasicMaterial({
    color: PAL.curtain,
    transparent: true,
    opacity: 0.036 + Math.random() * 0.020,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
    side: THREE.DoubleSide
  });

  // 水面y=6.2から海底y=-6.2へ、明るい光柱として差し込む
  // 横移動ではなく、上端を水面に残したまま縦方向の届きだけで進化を見せる
  const rayH = 19 + Math.random() * 8;
  const rayW = 1.0 + Math.random() * 1.9;
  const ry = new THREE.Mesh(
    new THREE.PlaneGeometry(rayW, rayH, 1, 1),
    rMat
  );
  ry.position.set(
    (Math.random() - 0.5) * 18,
    6.2 - rayH / 2,
    -1.2 - Math.random() * 5.2
  );
  ry.rotation.y = (Math.random() - 0.5) * 0.22;
  ry.userData = {
    p: Math.random() * Math.PI * 2,
    sway: 0.08 + Math.random() * 0.12,
    x0: ry.position.x,
    z0: ry.position.z,
    h: rayH,
    w: rayW,
    d: 0.88 + Math.random() * 0.34,
    baseOpacity: 0.038 + Math.random() * 0.014,
    m: rMat
  };
  oceanGroup.add(ry);
  rays.push(ry);
}

const ocLightGroup = new THREE.Group();
ocLightGroup.add(new THREE.AmbientLight(0x002233,1.2));
