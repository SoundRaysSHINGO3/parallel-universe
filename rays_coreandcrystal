function initAudio(){
  if(!aCtx) {
    aCtx = new (window.AudioContext || window.webkitAudioContext)();
    aNode = aCtx.createAnalyser();
    aNode.fftSize = 64;
    aNode.smoothingTimeConstant = 0.82;
    dArr = new Uint8Array(aNode.frequencyBinCount);

    mGain = aCtx.createGain();
    mGain.gain.value = 0;
    cBus = aCtx.createGain();
    cBus.gain.value = 0;
    dBus = aCtx.createGain();
    dBus.gain.value = 0;

    cBus.connect(mGain);
    dBus.connect(mGain);
    mGain.connect(aNode);
    aNode.connect(aCtx.destination);
  }

  o1A = [];
  o2A = [];
  g1A = [];
  g2A = [];

  CHORDS[0].forEach((f,i)=>{
    const o1 = aCtx.createOscillator();
    o1.type = 'sine';
    o1.frequency.value = f;
    const g1 = aCtx.createGain();
    g1.gain.value = 0.5 / 5;
    o1.connect(g1);
    g1.connect(cBus);
    o1.start();
    o1A.push(o1);
    g1A.push(g1);

    const o2 = aCtx.createOscillator();
    o2.type = 'triangle';
    o2.frequency.value = f * 2.003;
    const g2 = aCtx.createGain();
    g2.gain.value = 0.15 / 5;
    o2.connect(g2);
    g2.connect(cBus);
    o2.start();
    o2A.push(o2);
    g2A.push(g2);

    const lfo = aCtx.createOscillator();
    lfo.frequency.value = 0.22 + i * 0.06;
    const lg = aCtx.createGain();
    lg.gain.value = f * 0.004;
    lfo.connect(lg);
    lg.connect(o1.frequency);
    lfo.start();
  });
}

function setFreq(idx, t){
  CHORDS[idx].forEach((f,i)=>{
    o1A[i].frequency.linearRampToValueAtTime(f, t + 2.5);
    o2A[i].frequency.linearRampToValueAtTime(f * 2.003, t + 2.5);
    g1A[i].gain.linearRampToValueAtTime(0.5 / 5, t + 2.5);
    g2A[i].gain.linearRampToValueAtTime(0.15 / 5, t + 2.5);
  });
}

function buildDeep(){
  dNodes = [];

  [30,45,60,96].forEach((f,i)=>{
    const o = aCtx.createOscillator();
    o.type = 'sine';
    o.frequency.value = f;

    const g = aCtx.createGain();
    g.gain.value = 0;

    const l = aCtx.createOscillator();
    l.frequency.value = 0.08 + i * 0.04;
    const lg = aCtx.createGain();
    lg.gain.value = i===3 ? 0.018 : 0.04;
    l.connect(lg);
    lg.connect(g.gain);

    o.connect(g);
    g.connect(dBus);
    o.start();
    l.start();

    g.gain.setValueAtTime(0, aCtx.currentTime);
    g.gain.linearRampToValueAtTime(i===3 ? 0.025 : 0.08 + i * 0.015, aCtx.currentTime + 3);
    dNodes.push({o,g,l});
  });

  const nb = aCtx.createBuffer(1, aCtx.sampleRate*2, aCtx.sampleRate);
  const d = nb.getChannelData(0);
  for(let i=0;i<nb.length;i++) d[i] = Math.random()*2 - 1;

  const ns = aCtx.createBufferSource();
  ns.buffer = nb;
  ns.loop = true;

  const l1 = aCtx.createBiquadFilter();
  l1.type = 'lowpass';
  l1.frequency.value = 180;

  const g = aCtx.createGain();
  g.gain.value = 0;

  ns.connect(l1);
  l1.connect(g);
  g.connect(dBus);
  ns.start();

  g.gain.setValueAtTime(0, aCtx.currentTime);
  g.gain.linearRampToValueAtTime(0.06, aCtx.currentTime + 2.5);
  dNodes.push({o:ns,g});
}

function ensureDeepBed(){
  if(aCtx && !dNodes) buildDeep();
}

function enterMemoryAmbience(){
  if(!aCtx) return;

  ensureDeepBed();
  aCtx.resume();
  cBus.gain.cancelScheduledValues(aCtx.currentTime);
  dBus.gain.cancelScheduledValues(aCtx.currentTime);
  mGain.gain.cancelScheduledValues(aCtx.currentTime);

  cBus.gain.setValueAtTime(cBus.gain.value, aCtx.currentTime);
  dBus.gain.setValueAtTime(dBus.gain.value, aCtx.currentTime);
  mGain.gain.setValueAtTime(mGain.gain.value, aCtx.currentTime);

  cBus.gain.linearRampToValueAtTime(0.0, aCtx.currentTime + 1.6);
  dBus.gain.linearRampToValueAtTime(0.22, aCtx.currentTime + 2.2);
  mGain.gain.linearRampToValueAtTime(0.32, aCtx.currentTime + 2.2);

  if(dNodes){
    dNodes.forEach((n, i) => {
      if(n.g && n.g.gain){
        const target = i === dNodes.length - 1 ? 0.02 : 0.045 + i * 0.01;
        n.g.gain.cancelScheduledValues(aCtx.currentTime);
        n.g.gain.setValueAtTime(n.g.gain.value, aCtx.currentTime);
        n.g.gain.linearRampToValueAtTime(target, aCtx.currentTime + 2.2);
      }
    });
  }

  spaceAmbienceOn = true;
}

function clearMemoryAmbience(t = aCtx ? aCtx.currentTime : 0){
  if(!aCtx) return;
  cBus.gain.linearRampToValueAtTime(0.0, t + 1.2);
  dBus.gain.linearRampToValueAtTime(0.0, t + 1.4);
  mGain.gain.linearRampToValueAtTime(0.0, t + 1.6);
  spaceAmbienceOn = false;
}

function disposeDeepBed(delayMs = 0){
  if(!dNodes) return;
  const oldNodes = dNodes;
  setTimeout(() => {
    oldNodes.forEach(n => { try { n.o.stop(); } catch(e){} });
    if(dNodes === oldNodes) dNodes = null;
  }, delayMs);
}

function actMode(m, t){
  const p = cMode;
  cMode = m;

  if(m === 3){
    cBus.gain.linearRampToValueAtTime(0, t + 1.8);
    dBus.gain.linearRampToValueAtTime(0.9, t + 2);
    buildDeep();
  } else {
    if(p === 3){
      dBus.gain.linearRampToValueAtTime(0, t + 2);
      cBus.gain.linearRampToValueAtTime(0.16, t + 2.8);
      setFreq(m, t + 0.5);
      setTimeout(()=>{
        if(dNodes){
          dNodes.forEach(n => { try { n.o.stop(); } catch(e){} });
          dNodes = null;
        }
      }, 2300);
    } else {
      cBus.gain.linearRampToValueAtTime(0.16, t + 2);
      setFreq(m, t);
    }
  }

  ocPrompt.style.opacity = '1';
  ocPrompt.innerHTML = C_NAMES[m];
  setTimeout(()=>ocPrompt.style.opacity='0', 3500);
}

function handleOceanClick(){
  if(!aReady){
    initAudio();
    mGain.gain.linearRampToValueAtTime(0.9, aCtx.currentTime + 3);
    cBus.gain.linearRampToValueAtTime(0.16, aCtx.currentTime + 3);
    aReady = true;
    isPlay = true;
    cMode = 0;
    cStep = 0;
    spaceAmbienceOn = false;
    actMode(0, aCtx.currentTime);
  }
  else if(!isPlay){
    aCtx.resume();
    if(spaceAmbienceOn){
      dBus.gain.linearRampToValueAtTime(0.0, aCtx.currentTime + 1.5);
      disposeDeepBed(1700);
      spaceAmbienceOn = false;
    }
    mGain.gain.linearRampToValueAtTime(0.9, aCtx.currentTime + 2);
    isPlay = true;
    cMode = 0;
    cStep = 0;
    actMode(0, aCtx.currentTime);
  }
  else {
    cStep++;
    if(cStep === 1) actMode(1, aCtx.currentTime);
    else if(cStep === 2) actMode(2, aCtx.currentTime);
    else if(cStep === 3) actMode(3, aCtx.currentTime);
    else if(cStep === 4) actMode(0, aCtx.currentTime);
    else {
      cBus.gain.linearRampToValueAtTime(0, aCtx.currentTime + 2.6);
      dBus.gain.linearRampToValueAtTime(0, aCtx.currentTime + 2.8);
      isPlay = false;
      cStep = -1;
      ocPrompt.style.opacity = '1';
      ocPrompt.innerHTML = 'SILENT MODE';
      setTimeout(()=>aCtx.suspend(), 3000);
    }
  }
}

function triggerWormhole() {
