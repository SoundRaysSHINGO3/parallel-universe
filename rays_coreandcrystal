const ST = {
  WRIGGLING:0,
  CONVERGING:1,
  GLASS:2,
  DROPPING:3,
  IMPACT:4,
  OCEAN:5,
  WORMHOLE:6
};

let state = ST.WRIGGLING;
let convT = 0;
let dropVY = 0;
let switched = false;
let wormholeT = 0;
let holdSpike = 0;
let memoryUniverse = false;
let spaceAmbienceOn = false;

const spUi    = document.getElementById('space-ui');
const spTitle = document.getElementById('sp-title');
const spPhase = document.getElementById('sp-phase');
const spMsg   = document.getElementById('sp-msg');
const spHint  = document.getElementById('sp-hint');
const ocUi    = document.getElementById('ocean-ui');

let pDownT = 0;
let isPDown = false;
let pMoved = false;
let sx = 0, sy = 0;
let drag = false;
let px = 0, py = 0;
let vx = 0, vy = 0;

renderer.domElement.addEventListener('pointerdown', (e) => {
  isPDown = true;
  pMoved = false;
  pDownT = performance.now();
  sx = e.clientX;
  sy = e.clientY;
  px = e.clientX;
  py = e.clientY;
  vx = 0;
  vy = 0;
  drag = true;
});

window.addEventListener('pointermove', (e) => {
  if(!drag) return;

  if(Math.abs(e.clientX-sx) > 10 || Math.abs(e.clientY-sy) > 10) pMoved = true;
  vx = (e.clientX - px) * 0.01;
  vy = (e.clientY - py) * 0.01;

  if(state < ST.IMPACT){
    coreMesh.rotation.y += vx;
    coreMesh.rotation.x += vy;
  } else if (state === ST.OCEAN) {
    cryPivot.rotation.y += vx;
    cryPivot.rotation.x += vy;
    wrPivot.rotation.y += vx;
    wrPivot.rotation.x += vy;
  }

  px = e.clientX;
  py = e.clientY;
});

window.addEventListener('pointerup', () => {
  isPDown = false;
  drag = false;

  if(!pMoved){
    if(state === ST.WRIGGLING){
      if(performance.now() - pDownT > 600){
        state = ST.CONVERGING;
        spPhase.textContent = 'CONVERGING';
        spHint.style.opacity = '0';
        spMsg.textContent = "物質の再構築を開始します";
        spMsg.style.color = 'rgba(210,220,255,0.88)';
        setTimeout(() => { spMsg.style.color = 'rgba(210,220,255,0.0)'; }, 3200);
      } else {
        spMsg.textContent = "— 意識を集中し、長押ししてください —";
        spMsg.style.color = 'rgba(170,190,255,0.95)';
        setTimeout(() => {
          if(state===ST.WRIGGLING) spMsg.style.color = 'rgba(170,190,255,0.0)';
        }, 2000);
      }
    } else if(state === ST.GLASS){
      state = ST.DROPPING;
      spPhase.textContent = 'DROPPING TO OCEAN';
      spHint.style.opacity = '0';
    } else if(state === ST.OCEAN){
      if(cMode === 3 && isPlay){
        const mouse = new THREE.Vector2(
          (sx / innerWidth) * 2 - 1,
          -(sy / innerHeight) * 2 + 1
        );
        const raycaster = new THREE.Raycaster();
        raycaster.setFromCamera(mouse, camera);
        if (raycaster.intersectObject(singHit, true).length > 0) {
          triggerWormhole();
          return;
        }
      }
      handleOceanClick();
    }
  }
});

