  if(dNodes){
    dNodes.forEach((n, i) => {
      if(n.g && n.g.gain){
        const target = i === dNodes.length - 1 ? 0.02 : 0.05 + i * 0.01;
        n.g.gain.linearRampToValueAtTime(target, aCtx.currentTime + 1.4);
      }
    });
  }
}

