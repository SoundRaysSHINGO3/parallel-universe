function lerp(a,b,t){ return a + (b-a)*t; }
function smoothstep(x){ x = Math.max(0, Math.min(1, x)); return x*x*(3-2*x); }
function noise(t,freq,phase){ return Math.sin(t*freq+phase)*Math.cos(t*freq*0.73+phase*1.31); }
function noise2(t,freq,phase){ return Math.cos(t*freq*1.17+phase*0.89)*Math.sin(t*freq*0.61+phase*1.77); }
function noise3(t,freq,phase){ return Math.sin(t*freq*1.3+phase*2.1); }

// ============================================================
// 7. メインレンダリングループ
// ============================================================
const clock = new THREE.Clock();
let elapsed = 0;

function animate(){
  requestAnimationFrame(animate);

  const dt = Math.min(clock.getDelta(), 0.05);
  elapsed += dt;

  // ── SPACE フェーズ ──
  if(state < ST.IMPACT){
    // 宇宙フェーズ全体で背景色を統一（WRIGGLING/CONVERGING/GLASS/DROPPING 全て）
    renderer.setClearColor(memoryUniverse ? PAL.memoryBg : PAL.spaceBg, 1);

    let noiseAmp = 1.0;

    if(state === ST.WRIGGLING){
      if(isPDown && !pMoved){
        const holdMs = Math.max(0, performance.now() - pDownT - 120);
        const target = Math.min(1, holdMs / 900);
        holdSpike += (target - holdSpike) * 0.12;

        fresnelMat.uniforms.opacity.value =
          0.56 + 0.22 * Math.sin(elapsed * 2.0) + holdSpike * 0.42;
      } else {
        holdSpike += (0 - holdSpike) * 0.10;

        fresnelMat.uniforms.opacity.value =
          0.56 + 0.22 * Math.sin(elapsed * 2.0) + holdSpike * 0.10;
      }

      if (flashMat.opacity > 0) {
        flashMat.opacity = Math.max(0, flashMat.opacity - dt * 0.5);
      }
    } else {
      holdSpike += (0 - holdSpike) * 0.12;
    }

    if(state === ST.CONVERGING){
      convT = Math.min(convT + dt / CONV_DUR, 1.0);
      noiseAmp = 1.0 - smoothstep(convT);
      fresnelMat.uniforms.opacity.value = lerp(0.76, 0.0, smoothstep(convT));
      if(convT >= 1.0){
        state = ST.GLASS;
        spPhase.textContent = 'PURE GLASS';
        spTitle.classList.add('glass-mode');
        spHint.textContent = 'CLICK TO DROP';
        spHint.style.opacity = '1';
        noiseAmp = 0;
      }
    } else if(state >= ST.GLASS){
      noiseAmp = 0;
      convT = 1.0;
    }

    const positions = sphereGeo.attributes.position.array;
    for(let i=0; i<vertN; i++){
      const ox = origPos[i*3];
      const oy = origPos[i*3+1];
      const oz = origPos[i*3+2];

      if(noiseAmp > 0.001 || holdSpike > 0.001){
        const f = noiseFreq[i];
        const aR = noiseAmpR[i];
        const aT = noiseAmpT[i];
        const p = noisePhase[i];

        const len = Math.sqrt(ox*ox + oy*oy + oz*oz);
        const nx = ox / len;
        const ny = oy / len;
        const nz = oz / len;

        const n1 = noise(elapsed, f, p);
        const n2 = noise(elapsed, f * 0.5, p + 2.1);
        const fuzz = noise3(elapsed, f * 6.0, p) * 0.015;

        const baseDisp = noiseAmp * (aR * (n1 * 0.7 + n2 * 0.3) + fuzz);
        const n3 = noise2(elapsed, f * 0.8, p + 1.4);

        const spikeA = Math.pow(
          Math.max(
            0,
            Math.sin(elapsed * 10.0 + p * 2.7 + nx * 8.5 + ny * 7.3 + nz * 9.1)
          ),
          5.0
        );

        const spikeB = Math.pow(
          Math.max(
            0,
            Math.sin(elapsed * 13.0 + p * 3.9 + nx * 12.0 - ny * 10.0 + nz * 11.0)
          ),
          6.0
        );

        const spikeDisp =
          holdSpike * (0.05 + aR * 0.45) * (spikeA * 0.7 + spikeB * 0.3);

        const pulseDisp =
          holdSpike * Math.sin(elapsed * 7.0 + p) * 0.018;

        const disp = baseDisp + spikeDisp + pulseDisp;

        const ty = nz;
        const tz = -ny;
        const tLen = Math.sqrt(ty*ty + tz*tz) + 0.001;

        const tang =
          noiseAmp * aT * n3 +
          holdSpike * 0.035 * Math.sin(elapsed * 9.0 + p * 1.7 + nx * 6.0);

        positions[i*3]   = ox + nx * disp + (ty / tLen) * tang * 0.6;
        positions[i*3+1] = oy + ny * disp;
        positions[i*3+2] = oz + nz * disp + (tz / tLen) * tang * 0.6;
      } else {
        positions[i*3]   = ox;
        positions[i*3+1] = oy;
        positions[i*3+2] = oz;
      }
    }
    sphereGeo.attributes.position.needsUpdate = true;
    sphereGeo.computeVertexNormals();

    const mt = smoothstep(convT);
    matCore.color.setRGB(
      lerp(PW.cR, PG.cR, mt),
      lerp(PW.cG, PG.cG, mt),
      lerp(PW.cB, PG.cB, mt)
    );
    matCore.emissiveIntensity = lerp(PW.em, 0, mt);
    matCore.metalness = lerp(PW.m, PG.m, mt);
    matCore.roughness = lerp(PW.r, PG.r, mt);
    matCore.opacity = lerp(PW.op, PG.op, mt);
    matCore.transmission = lerp(0, 0.95, Math.max(0, mt * 1.5 - 0.5));

    const preDropGlass = (state >= ST.GLASS && state < ST.DROPPING);

    bloom1Mat.opacity =
      lerp(0.06, 0.024, mt) +
      (state === ST.WRIGGLING
        ? (0.012 + Math.sin(elapsed * 1.9) * 0.008)
        : (preDropGlass ? (0.004 + Math.sin(elapsed * 1.6) * 0.002) : 0)) +
      holdSpike * 0.06;

    bloom2Mat.opacity =
      lerp(0.028, 0.012, mt) +
      (state === ST.WRIGGLING
        ? (0.006 + Math.sin(elapsed * 2.4) * 0.004)
        : (preDropGlass ? (0.002 + Math.sin(elapsed * 1.9) * 0.0015) : 0)) +
      holdSpike * 0.035;

    wireMat.opacity = lerp(0.07, 0.0, mt) + holdSpike * 0.03;

    if(state >= ST.GLASS){
      matCore.envMap = cubeRT.texture;
      matCore.envMapIntensity = 2.0;
      matCore.needsUpdate = true;

      coreMesh.visible = false;
      wireMesh.visible = false;
      fresnelMesh.visible = false;
      bloomShell1.visible = false;
      bloomShell2.visible = false;
      coreGlitter.visible = false;

      cubeCamera.position.copy(coreMesh.position);
      cubeCamera.update(renderer, scene);

      coreMesh.visible = true;
      wireMesh.visible = (state < ST.DROPPING);
      fresnelMesh.visible = true;
      bloomShell1.visible = true;
      bloomShell2.visible = true;
      coreGlitter.visible = true;

      fresnelMat.uniforms.opacity.value = 0.18 + Math.sin(elapsed * 2.8) * 0.04;
    }

    if(state === ST.DROPPING){
      dropVY -= 0.006 * (1.0 + Math.min(Math.abs(coreMesh.position.y) / 16, 1) * 3);
      coreMesh.position.y += dropVY;
      wireMesh.position.y = coreMesh.position.y;
      fresnelMesh.position.y = coreMesh.position.y;
      coreMesh.rotation.z += 0.015;

      bloomShell1.position.copy(coreMesh.position);
      bloomShell2.position.copy(coreMesh.position);
      coreGlitter.position.copy(coreMesh.position);

      if(coreMesh.position.y < -20){
        state = ST.IMPACT;
        flashMat.opacity = 1.0;
        spUi.style.opacity = '0';
      }
    }

    if(!drag && state < ST.DROPPING){
      coreMesh.rotation.y += 0.003;
      coreMesh.rotation.x += 0.0008;
      vx = 0;
      vy = 0;
    } else if(!drag){
      vx *= 0.88;
      vy *= 0.88;
      coreMesh.rotation.y += vx;
      coreMesh.rotation.x += vy;
    }

    wireMesh.rotation.copy(coreMesh.rotation);
    fresnelMesh.rotation.copy(coreMesh.rotation);
    bloomShell1.rotation.copy(coreMesh.rotation);
    bloomShell2.rotation.copy(coreMesh.rotation);

    const memoryVisible = memoryUniverse && state === ST.WRIGGLING;
    memoryCorePivot.visible = memoryVisible;
    if(memoryVisible){
      const orbitX = 1.9 + Math.sin(elapsed * 0.8) * 0.18;
      const orbitY = 0.62 + Math.sin(elapsed * 1.6) * 0.20;
      const orbitZ = 0.55 + Math.cos(elapsed * 0.95) * 0.26;
      memoryCorePivot.position.set(
        coreMesh.position.x + orbitX,
        coreMesh.position.y + orbitY,
        coreMesh.position.z + orbitZ
      );
      memoryCorePivot.rotation.y += 0.025;
      memoryCorePivot.rotation.x += 0.012;
      memoryCoreHalo.rotation.x -= 0.018;
      memoryCoreHalo.rotation.y += 0.014;
      memoryCoreTrail.scale.setScalar(1.0 + Math.sin(elapsed * 2.2) * 0.08);
      memoryCore.material.opacity = 0.78 + Math.sin(elapsed * 2.8) * 0.12;
      memoryCoreHalo.material.opacity = 0.18 + Math.sin(elapsed * 2.0) * 0.06;
    }

    fresnelMat.uniforms.color.value.set(memoryUniverse ? 0x8fcfff : 0xc26cff);
    bloom2Mat.color.setHex(memoryUniverse ? 0x7fe9ff : 0x39dfff);

    const gp = coreGlitterGeo.attributes.position.array;
    for(let i=0; i<CORE_GLITTER_COUNT; i++){
      const ix = i * 3;
      const s = coreGlitterSeed[i];
      gp[ix]   = coreGlitterBase[ix]   + Math.sin(elapsed * 1.8 + s) * 0.028;
      gp[ix+1] = coreGlitterBase[ix+1] + Math.cos(elapsed * 1.5 + s * 1.3) * 0.028;
      gp[ix+2] = coreGlitterBase[ix+2] + Math.sin(elapsed * 2.1 + s * 0.7) * 0.028;
    }
    coreGlitterGeo.attributes.position.needsUpdate = true;

    coreGlitter.rotation.y += 0.0018;
    coreGlitter.rotation.x -= 0.0007;
    coreGlitterMat.opacity =
      Math.max(0, lerp(0.72, 0.0, mt) + Math.sin(elapsed * 3.2) * 0.06 + holdSpike * 0.12);

    dynLights[0].l.position.set(
      dynLights[0].b[0] * Math.cos(elapsed * 0.35),
      dynLights[0].b[1] * Math.sin(elapsed * 0.25),
      dynLights[0].b[2]
    );
    dynLights[1].l.position.set(
      dynLights[1].b[0] * Math.cos(elapsed * 0.28),
      dynLights[1].b[1] * Math.sin(elapsed * 0.22),
      dynLights[1].b[2]
    );

    nebulaParticles.forEach((p,i)=>{
      p.rotation.y += (i % 2 === 0 ? 0.00015 : -0.0001);
    });
    glitterDust.rotation.y += 0.00018;
    glitterDust.rotation.x -= 0.00006;
  }

  // ── 次元切り替え ──
  if(state === ST.IMPACT){
    if(flashMat.opacity >= 1.0 && !switched){
      spaceGroup.visible = false;
      oceanGroup.visible = true;
      renderer.setClearColor(PAL.oceanBg, 1);
      scene.fog = new THREE.FogExp2(PAL.oceanFog, 0.032);
      setTimeout(() => ocUi.style.opacity = '1', 800);
      switched = true;
    }

    if(switched){
      flashMat.opacity = Math.max(0, flashMat.opacity - 0.02);
      if(flashMat.opacity <= 0) state = ST.OCEAN;
    }
  }

  // ── OCEAN フェーズ ──
  if(state === ST.OCEAN || (state === ST.IMPACT && switched) || state === ST.WORMHOLE){
    const bp = bubbleGeo.attributes.position;
    for(let i=0;i<O_BUBBLE_COUNT;i++){
      bp.array[i*3+1] += (cMode === 3 ? bubbleSpd[i] * 0.4 : bubbleSpd[i]);
      bp.array[i*3]   += Math.sin(elapsed * 0.6 + bubbleDrf[i]) * 0.003;
      if(bp.array[i*3+1] > 12){
        bp.array[i*3+1] = -12;
        bp.array[i*3] = (Math.random() - .5) * 20;
      }
    }
    bp.needsUpdate = true;

    let nrm = 0;
    if(aReady && aNode){
      aNode.getByteFrequencyData(dArr);
      if(isPlay){
        nrm = dArr.reduce((s,v)=>s+v,0) / dArr.length / 255;
        for(let i=0;i<20;i++){
          const v = dArr[Math.min(i * 3, dArr.length - 1)] / 255;
          bars[i].style.height = (2 + v * 34) + 'px';
          bars[i].style.opacity = 0.25 + v * 0.75;
          bars[i].style.background = `hsla(${cMode===3?290:185+v*40},80%,65%,0.9)`;
        }
      } else {
        for(let i=0;i<20;i++){
          bars[i].style.height = '2px';
          bars[i].style.opacity = '0.12';
        }
      }
    }

    const wsPos = waterSurfaceGeo.attributes.position.array;
    for(let i=0; i<wsPos.length/3; i++){
      const ix = i * 3;
      const bx = waterSurfaceBase[ix];
      const by = waterSurfaceBase[ix + 1];
      const h =
        Math.sin(elapsed * 1.15 + bx * 0.22 + by * 0.18) * 0.16 +
        Math.cos(elapsed * 0.72 + bx * 0.14 - by * 0.16) * 0.08 +
        nrm * Math.sin(elapsed * 1.6 + bx * 0.28) * 0.08;
      wsPos[ix + 2] = h;
    }
    waterSurfaceGeo.attributes.position.needsUpdate = true;
    waterSurfaceGeo.computeVertexNormals();

    rays.forEach((r) => {
      const breath = 0.5 + 0.5 * Math.sin(elapsed * 0.55 + r.userData.p);

      // ── 「宇宙の太陽の光が立体に近づいていく」演出 ──────────────
      // cMode 0: 水面付近のほのかな光（まだ遠い）
      // cMode 1: 少し深く届き始める
      // cMode 2: 立体の高さまで届く（宇宙への郷愁が芽生える）
      // cMode 3: マカバ全開・光が立体を包む（宇宙へ帰るトリガー）
      const modeFactor = cMode / 3; // 0, 0.33, 0.66, 1.0

      // opacityの上限：マカバまで抑える
      const opacityMax = cMode === 3
        ? 0.17                              // マカバ：全開
        : 0.028 + modeFactor * 0.044;       // 0:0.028, 1:0.043, 2:0.057

      // 音圧の影響：cModeが上がるほど音に反応しやすくなる
      const nrmGain = cMode === 3
        ? 0.075
        : 0.010 + modeFactor * 0.016;       // 0:0.010, 1:0.015, 2:0.021

      // 到達深度：cModeが上がると光が下まで伸びる
      const triggerReach = THREE.MathUtils.clamp(
        modeFactor * 0.50 + nrm * (0.15 + modeFactor * 0.20),
        0, 1
      );
      const depthReach = smoothstep(triggerReach);

      // scaleY：水面上端を固定して下方向へ伸ばす
      const rayScaleY = 1.0
        + r.userData.d * (0.04 + depthReach * (0.10 + modeFactor * 0.22))
        + nrm * (0.05 + modeFactor * 0.12)
        + breath * 0.025;
      const rayScaleX = 1.0 + nrm * 0.06 + breath * 0.025;

      r.scale.x = rayScaleX;
      r.scale.y = rayScaleY;
      r.position.y = 6.2 - (r.userData.h * rayScaleY) / 2;

      r.userData.m.opacity = THREE.MathUtils.clamp(
        r.userData.baseOpacity * (0.3 + modeFactor * 0.7) +
        breath * 0.005 +
        Math.sin(elapsed * 0.32 + r.userData.p) * 0.003 +
        depthReach * 0.010 * (0.2 + modeFactor * 0.8) +
        nrm * nrmGain,
        r.userData.baseOpacity * 0.2,
        opacityMax
      );

      const driftX = Math.sin(elapsed * 0.18 + r.userData.p) * r.userData.sway;
      const driftZ = Math.cos(elapsed * 0.15 + r.userData.p) * r.userData.sway * 0.30;
      r.position.x = r.userData.x0 + driftX;
      r.position.z = r.userData.z0 + driftZ;
    });

    singPivot.visible = (cMode === 3 && isPlay && state === ST.OCEAN);
    if(singPivot.visible) {
      singPivot.rotation.y = elapsed * 0.6;
      singPivot.rotation.x = Math.sin(elapsed * 0.5) * 0.2;
      singularity.scale.setScalar(1.0 + Math.sin(elapsed * 4.0) * 0.2);
    }

    const m = VIS[cMode];
    const sc = 1 + nrm * (cMode===3 ? 2.2 : 1.5);
    cryPivot.scale.setScalar(sc);
    wrPivot.scale.setScalar(sc * 1.004);

    const icosaBirth = (cMode === 2 && isPlay) ? 1 : 0;
    const icosaPulse = 1.0 + Math.sin(elapsed * 3.1) * 0.10 + nrm * 0.14;
    const birthTremor = 0.5 + 0.5 * Math.sin(elapsed * 8.5);
    // 子コア：球体から立体へ向かう前兆として、わずかにトゲ感のある呼吸を与える
    icosaInnerLight.rotation.y += 0.026;
    icosaInnerLight.rotation.x -= 0.012;
    const baseScale = 1.0 + icosaBirth * (0.18 + icosaPulse * 0.10);
    const sx = baseScale * (1.0 + icosaBirth * (0.03 + birthTremor * 0.05));
    const sy = baseScale * (1.0 - icosaBirth * 0.03 + Math.sin(elapsed * 5.2) * 0.015);
    const sz = baseScale * (1.0 + icosaBirth * (0.02 + (1.0 - birthTremor) * 0.04));
    icosaInnerLight.scale.set(sx, sy, sz);
    icosaInnerLight.material.opacity = THREE.MathUtils.clamp(
      icosaBirth * (0.84 + Math.sin(elapsed * 3.0) * 0.08 + nrm * 0.20),
      0,
      0.98
    );
    // 子コアを内側から照らす黄色PointLight
    icosaYellowLight.intensity = icosaBirth * (3.0 + Math.sin(elapsed * 2.6) * 0.6 + nrm * 1.9);

    shapes.forEach((s,idx)=>{
      s.c.userData.s += ((idx===cMode && isPlay ? 1 : (idx===0 && !isPlay ? 1 : 0.001)) - s.c.userData.s) * 0.06;
      if(s.c.userData.s < 0.01){
        s.c.visible = false;
        s.w.visible = false;
      } else {
        s.c.visible = true;
        s.w.visible = true;
        s.c.scale.setScalar(s.c.userData.s);
        s.w.scale.setScalar(s.c.userData.s);
      }
    });

    const h = m.h + nrm * (cMode===3 ? 0.06 : 0.12) + (cMode===3 ? Math.sin(elapsed * 0.2) * 0.03 : 0);
    matCry.color.setHSL(h, m.s, m.l);
    matWr.color.setHSL(h, m.s, m.l + 0.1);

    let eI = m.ei[0] + nrm * m.ei[1];
    let cB = m.bl[0] + nrm * m.bl[1];
    if(cMode===3 && isPlay && state !== ST.WORMHOLE){
      const b = Math.sin(elapsed * 1.2) * 0.4 + 0.2;
      eI += b * 0.8;
      cB += b;
    }

    matCry.emissive.setHSL(h, m.es, m.el);
    matCry.emissiveIntensity = eI;
    bloomPass.strength = isPlay ? cB : 0.2;
    pLight.intensity = m.p[0] + nrm * m.p[1];
    cLight.intensity = m.c[0] + nrm * m.c[1];
    cLight.color.setHSL(h, 0.9, 0.5);

    if(state === ST.OCEAN) {
      const cA = cMode === 3 ? 0.22 : 0.12;
      camera.position.x = Math.sin(elapsed * (cMode===3 ? 0.04 : 0.07)) * cA;
      camera.position.y = Math.cos(elapsed * (cMode===3 ? 0.03 : 0.05)) * cA * 0.7;
      camera.lookAt(0,0,0);

      if(!drag){
        cryPivot.rotation.x += 0.005 + nrm * 0.012;
        cryPivot.rotation.y += 0.01  + nrm * 0.018;
        wrPivot.rotation.copy(cryPivot.rotation);
        vx *= 0.88;
        vy *= 0.88;
      } else {
        vx *= 0.88;
        vy *= 0.88;
        cryPivot.rotation.y += vx;
        cryPivot.rotation.x += vy;
        wrPivot.rotation.copy(cryPivot.rotation);
      }
    }

    pLight.position.set(
      5 * Math.cos(elapsed * 0.3),
      4 * Math.sin(elapsed * 0.25),
      5 * Math.cos(elapsed * 0.2)
    );
  }

  // ── WORMHOLE ──
  if (state === ST.WORMHOLE) {
    wormholeT += dt;
    wormhole.material.uniforms.time.value = elapsed;

    cryPivot.rotation.y += 0.4;
    cryPivot.rotation.x += 0.2;
    wrPivot.rotation.copy(cryPivot.rotation);

    wormhole.scale.lerp(new THREE.Vector3(1,1,1), 0.05);
    camera.position.z -= dt * 18.0;

    if(wormholeT > 2.0) {
      flashMat.opacity = Math.min(1.0, flashMat.opacity + dt * 1.5);
    }
    if(wormholeT > 3.0) {
      resetToUniverse();
    }
  }

  composer.render();
}
animate();

window.addEventListener('resize', () => {
  camera.aspect = innerWidth / innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
  composer.setSize(innerWidth, innerHeight);
});
</script>
</body>
