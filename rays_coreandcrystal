  {h:0.50, s:0.62, l:0.50, es:0.78, el:0.14, ei:[0.28,0.95],bl:[0.6,1.0], p:[2.1,5.3], c:[0,4.0]},
  {h:0.82, s:0.85, l:0.45, es:0.95, el:0.25, ei:[0.40,1.2],bl:[1.5,3.0], p:[2.0,5.0], c:[0,6.0]}
];

let aCtx, aNode, dArr, mGain, cBus, dBus, dNodes = null;
let aReady = false, isPlay = false, cMode = 0, cStep = -1;
let o1A = [], o2A = [], g1A = [], g2A = [];

const ocPrompt = document.getElementById('oc-prompt');
